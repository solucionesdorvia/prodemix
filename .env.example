# Copy to `.env` or `.env.local` (Next.js + Prisma CLI leen ambos; `.env.local` pisa `.env`).
# In Railway: misma variable en Variables del servicio.

# Neon: Dashboard → Connection string → URI (incluí sslmode=require si Neon lo indica).

DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Con la URL lista, en la raíz del proyecto:
#   npm run db:setup          → migraciones + seed (respeta .env.local si existe)
#   npm run db:neon           → solo contra Neon (usa solo .env; ignora .env.local)
