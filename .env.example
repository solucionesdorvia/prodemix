# =============================================================================
# ProdeMix — environment variables
# Copy to `.env` locally. Never commit `.env` or real secrets (see `.gitignore`).
#
# Full audit: docs/environment.md
# Staging vs production, migrations, seed: docs/deployment.md
# =============================================================================

# --- Database (required in deployment) ---------------------------------------
# Neon: DATABASE_URL = pooled (-pooler). Opcional pero recomendado para migrate deploy:
# DIRECT_URL = misma base, host SIN "-pooler" (pestaña Connection en Neon).
DATABASE_URL=
# DIRECT_URL=

# --- Auth.js (NextAuth v5) — required in deployment --------------------------
# openssl rand -base64 32
AUTH_SECRET=

# Public origin, no trailing slash. Set per environment (staging URL vs production domain).
# On Vercel, optional if you only need defaults; explicit value recommended for OAuth + emails.
AUTH_URL=http://localhost:3000

# Legacy alias (optional; prefer AUTH_URL)
# NEXTAUTH_URL=http://localhost:3000

# --- Google OAuth (optional; both required to enable) ------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email: transactional (Resend) + reminders --------------------------------
# Guía: docs/resend-setup.md — crear API key en resend.com y verificar dominio para producción.
# Prueba rápida: EMAIL_FROM="ProdeMix <onboarding@resend.dev>"
EMAIL_FROM=
RESEND_API_KEY=
# Fallback SMTP si no usás Resend API (recordatorios / transaccional): Nodemailer
# EMAIL_SERVER=smtp://user:pass@smtp.example.com:587

# Cron HTTP trigger: GET /api/cron/reminders — Authorization: Bearer <secret>
CRON_SECRET=
REMINDER_WINDOW_HOURS=24

# --- Admin (/admin API) — optional but required for admin UI -------------------
# Long random string; same value used when logging in at /admin/login
ADMIN_SECRET=

# --- Client (build-time on Vercel: set per Environment) ----------------------
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_VERCEL_ENV=

# --- Observability (optional) ------------------------------------------------
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
